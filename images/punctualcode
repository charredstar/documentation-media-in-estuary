reduceOpacity factor x = x *: [1,1,1,factor];

brknincreaseSaturation factor x =  hsvrgb [mono $ x * [1,0,0,0],mono $ x * [0,1,0,0], mono $ x * [0,0,1,0]] ++ (mono $ x * [0,0,0,1]);

increaseSaturation factor x =  hsvrgb (rgbhsv [mono $ x *: [1,0,0,0],(mono $ x *: [0,1,0,0]), mono $ x *: [0,0,1,0]] +: [0,factor,0]) ++ (mono $ x *: [0,0,0,1]);

